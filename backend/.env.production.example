PORT=5001
TCP_PORT=5027
NODE_ENV=production
JWT_SECRET=use-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d

# Neon PostgreSQL (production) — replace with your credentials
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Real FMC150 — must match Teltonika config + devices table (run npm run seed-real-device)
REAL_DEVICE_IMEI=862129084847783
REAL_DEVICE_CCID=89234010006276368382
REAL_DEVICE_PLATE=LIVE-FMC150
REAL_DEVICE_TANK_LITERS=60

# Never enable simulator on EC2 production
ENABLE_FLEET_SIMULATOR=false
