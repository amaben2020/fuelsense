PORT=5001
TCP_PORT=5027
DATABASE_URL=postgresql://user:password@localhost:5434/fuelguard
NODE_ENV=development

# REQUIRED — must be ≥32 chars in production
JWT_SECRET=change-this-to-a-long-random-string-in-production

JWT_EXPIRES_IN=7d
FUEL_PRICE_NGN_LITER=1500

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,https://fuelsense.ng,https://www.fuelsense.ng

# OCR.space — free receipt OCR (register at https://ocr.space/ocrapi)
OCR_SPACE_API_KEY=

# Physical FMC150 (production / EC2)
REAL_DEVICE_IMEI=862129084847783
REAL_DEVICE_CCID=89234010006276368382

# Local demo simulators — off by default; set true only for dev
ENABLE_FLEET_SIMULATOR=false
SEED_DEMO_FLEET=false
