PORT=5001
TCP_PORT=5027
DATABASE_URL=postgresql://user:password@localhost:5434/fuelguard
NODE_ENV=development
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d
FUEL_PRICE_NGN_LITER=1340

