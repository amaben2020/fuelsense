{
  "name": "fuelguard-backend",
  "version": "1.0.0",
  "description": "FuelGuard Express API and Teltonika TCP server",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "seed": "tsx src/seed.ts",
    "seed-telemetry": "tsx src/seed-telemetry.ts",
    "mock-device": "tsx src/mock-device.ts",
    "simulate-fleet": "tsx src/fleet-simulator.ts",
    "test": "jest --runInBand",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push"
  },
  "keywords": [
    "teltonika",
    "fuel",
    "telemetry"
  ],
  "license": "MIT",
  "dependencies": {
    "@groupe-savoy/teltonika-sdk": "^0.3.1",
    "@upstash/redis": "^1.38.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.31.10",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
